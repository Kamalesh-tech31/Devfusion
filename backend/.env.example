# MongoDB Connection
# For local MongoDB: mongodb://localhost:27017/devfusion
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/devfusion
MONGO_URI=mongodb://localhost:27017/devfusion

# Server Configuration
PORT=4000
NODE_ENV=development

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# JWT Secret (optional, if implementing auth)
JWT_SECRET=your_jwt_secret_key_here

# Database Name
DATABASE_NAME=devfusion